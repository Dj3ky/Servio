# Application
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://servio:servio_password@localhost:5432/servio

# Authentication
JWT_SECRET=change_this_to_a_secure_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h

# Encryption key for SMTP/SMB passwords at rest (32 bytes hex = 64 chars)
ENCRYPTION_KEY=change_this_to_a_32_byte_hex_string_64_chars_exactly_here

# SMTP (initial config, can be overridden via Settings UI)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=smtp_password
SMTP_FROM=Servio <notifications@example.com>
SMTP_SECURE=false

# SMB Storage (initial config, can be overridden via Settings UI)
SMB_HOST=192.168.1.100
SMB_SHARE=reports
SMB_USERNAME=servio
SMB_PASSWORD=smb_password
SMB_BASE_PATH=

# Backup
BACKUP_PATH=./backups
